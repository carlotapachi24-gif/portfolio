---
import { Mail } from "@lucide/astro";
import { siteConfig } from "@/config/site.js";
import experiences from "@/collections/experiences.json";
import AboutExperience from "@/components/elements/AboutExperience.astro";
import Button from "@/components/ui/Button.astro";
import Layout from "@/layouts/Layout.astro";
import Toc from "@/components/widgets/Toc.astro";

const headings = [
  { depth: 2, slug: "perfil-profesional", text: "Perfil profesional" },
  { depth: 2, slug: "formacion", text: "Formación" },
  { depth: 2, slug: "competencias-tecnicas", text: "Competencias técnicas" },
  { depth: 2, slug: "experiencia-profesional", text: "Experiencia profesional" },
  { depth: 2, slug: "proyectos-destacados", text: "Proyectos destacados" },
  { depth: 2, slug: "capacidades-profesionales", text: "Capacidades profesionales" },
  { depth: 2, slug: "metodologia-de-trabajo", text: "Metodología de trabajo" },
  { depth: 2, slug: "filosofia-de-diseno", text: "Filosofía de diseño" },
  { depth: 2, slug: "sectores-de-experiencia", text: "Sectores de experiencia" },
  { depth: 2, slug: "habilidades-complementarias", text: "Habilidades complementarias" },
  { depth: 2, slug: "idiomas", text: "Idiomas" },
  { depth: 2, slug: "contacto", text: "Contacto" },
];

const filtered = headings.filter(h => h.depth <= 3);
---

<Layout title="Portfolio profesional">
  <div class="block lg:hidden px-7 pt-6">
    <Toc headings={filtered} />
  </div>

  <div class="relative site-container mx-auto my-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 xl:gap-16">
      <aside class="relative hidden lg:block lg:w-40 xl:w-50 flex-shrink-0">
        <div class="toc-sticky-wrapper">
          <Toc headings={filtered} />
        </div>
      </aside>

      <main class="relative flex-1 min-w-0 w-full lg:max-w-none">
        <div
          class="w-full"
          data-aos="fade-up-xs"
          data-aos-duration="500"
          data-aos-once="true"
        >
          <h1 class="text-3xl font-brand tracking-tight sm:text-4xl lg:text-5xl">
            Portfolio profesional
          </h1>
          <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-4 mb-8"></div>
        </div>

        <div
          class="flex items-center gap-4 mb-4"
          data-aos="fade-up-xs"
          data-aos-delay="100"
          data-aos-duration="500"
          data-aos-once="true"
        >
          <img src="/assets/avatar.png" alt="Carlota López Carracedo" class="w-14 h-14 rounded-full" />
          <div>
            <p class="text-2xl font-brand text-neutral-800 dark:text-neutral-100">
              Carlota López Carracedo
            </p>
            <p class="text-sm text-neutral-500">carlotalopecarracedo@gmail.com</p>
          </div>
        </div>

        <p
          class="text-neutral-700 pb-6 leading-[1.8] dark:text-neutral-200"
          data-aos="fade-up-xs"
          data-aos-delay="200"
          data-aos-duration="500"
          data-aos-once="true"
        >
          Creadora de contenido y diseñadora gráfica especializada en branding, diseño digital y producción audiovisual. Experiencia en desarrollo de identidades corporativas, diseño de materiales gráficos y gestión de contenido multiplataforma.
        </p>

        <div
          class="flex item-center justify-start gap-3"
          data-aos="fade-up-xs"
          data-aos-delay="300"
          data-aos-duration="500"
          data-aos-once="true"
        >
          <Button url={`mailto:${siteConfig.mail}`}>
            <Mail size={16} />
            Contacto
          </Button>
        </div>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section>
          <h2 id="perfil-profesional" class="mt-2 mb-3 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Perfil profesional
          </h2>
          <p class="text-neutral-700 leading-[1.8] dark:text-neutral-200">
            Enfoque creativo y estratégico para construir marcas consistentes y contenido que conecte con la audiencia. Especializada en identidad visual, diseño digital y producción audiovisual con orientación a resultados.
          </p>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section>
          <h2 id="formacion" class="mt-2 mb-3 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Formación
          </h2>
          <div class="space-y-3">
            <div>
              <p class="text-lg font-semibold text-neutral-800 dark:text-neutral-200">
                Grado en Publicidad y Relaciones Públicas
              </p>
              <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                <li>Universidad de Vigo | 2020-2024</li>
                <li>Universidad de Valladolid | 2022-2023</li>
                <li>Universidad Complutense de Madrid | 2023-2024</li>
              </ul>
            </div>
          </div>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section>
          <h2 id="competencias-tecnicas" class="mt-2 mb-3 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Competencias técnicas
          </h2>
          <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">
            Software de diseño
          </h3>
          <ul class="list-disc pl-5 mt-3 text-neutral-700 dark:text-neutral-200 leading-7">
            <li>Adobe Illustrator</li>
            <li>Adobe Photoshop</li>
            <li>Adobe InDesign</li>
            <li>Canva</li>
            <li>Figma</li>
            <li>DaVinci Resolve</li>
            <li>CapCut</li>
            <li>Procreate</li>
            <li>Elementor</li>
            <li>WordPress</li>
          </ul>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section class="experience">
          <h2 id="experiencia-profesional" class="mt-2 mb-4 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Experiencia profesional
          </h2>
          <div class="px-5 py-6">
            {experiences.map((experience, index) => (
              <div
                class="pb-10 border-l border-dashed border-gray-200 last:border-l-0 dark:border-neutral-500"
                data-aos="fade-up-xs"
                data-aos-delay={200 + (index * 100)}
                data-aos-duration="500"
                data-aos-once="true"
              >
                <AboutExperience
                  dates={experience.dates}
                  role={experience.role}
                  company={experience.company}
                  description={experience.description}
                  logo={experience.logo}
                />
              </div>
            ))}
          </div>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-2 mb-10"></div>

        <section>
          <h2 id="proyectos-destacados" class="mt-2 mb-4 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Proyectos destacados
          </h2>

          <div class="space-y-8">
            <div>
              <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-200">1. Quimeras del Norte</h3>
              <p class="text-sm text-neutral-500">Tipo: Branding e identidad visual</p>
              <p class="text-neutral-700 dark:text-neutral-200 leading-[1.8] mt-2">
                Proyecto de identidad corporativa para una plataforma web de narrativas gallegas. La propuesta se centra en trasladar historias y escritos de diversos personajes gallegos al entorno digital.
              </p>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Concepto</p>
                <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                  <li>Misión: Difundir narraciones e historias de diversos personajes a través de su propia página web.</li>
                  <li>Visión: Alcanzar visibilidad entre lectores y consumidores de contenidos online.</li>
                </ul>
              </div>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Elementos de identidad</p>
                <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                  <li>Color verde: representa naturaleza y el entorno del escritor.</li>
                  <li>Roble (carballo): árbol representativo de Galicia y eje de la identidad.</li>
                  <li>Quimera: referencia mitológica ligada al contenido imposible de las historias.</li>
                </ul>
              </div>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Entregables</p>
                <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                  <li>Logotipo con tipografía serif elegante.</li>
                  <li>Símbolo de árbol estilizado en verde.</li>
                  <li>Sistema de identidad visual completo.</li>
                  <li>Paleta de color corporativa.</li>
                </ul>
              </div>
            </div>

            <div>
              <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-200">2. Nobreh</h3>
              <p class="text-sm text-neutral-500">Tipo: Identidad corporativa | Gestión de inversiones</p>
              <p class="text-neutral-700 dark:text-neutral-200 leading-[1.8] mt-2">
                Desarrollo de imagen visual corporativa para una empresa familiar de gestión de inversiones compuesta por cinco miembros. Se creó una identidad visual desde cero.
              </p>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Requisitos del cliente</p>
                <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                  <li>Elegancia</li>
                  <li>Simplicidad</li>
                </ul>
              </div>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Concepto creativo</p>
                <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                  <li>Color amarillo: simboliza riqueza.</li>
                  <li>Trébol: indica fortuna.</li>
                  <li>5 hojas: representa el número de integrantes de la familia.</li>
                </ul>
              </div>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Solución de diseño</p>
                <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                  <li>Logotipo limpio y elegante con tipografía serif.</li>
                  <li>Símbolo de trébol de 5 hojas estilizado.</li>
                  <li>Color dorado/amarillo como principal.</li>
                  <li>Sistema de identidad minimalista y sofisticado.</li>
                </ul>
              </div>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Entregables</p>
                <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                  <li>Marca principal y secundaria.</li>
                  <li>Símbolo gráfico explicado conceptualmente.</li>
                  <li>Manual de identidad visual.</li>
                </ul>
              </div>
            </div>

            <div>
              <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-200">3. Vitamina 3</h3>
              <p class="text-sm text-neutral-500">Tipo: Branding | Proyecto universitario</p>
              <p class="text-neutral-700 dark:text-neutral-200 leading-[1.8] mt-2">
                Proyecto universitario desarrollado por duplas creativas que refleja los valores del equipo y el potencial profesional conjunto.
              </p>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Concepto</p>
                <p class="text-neutral-700 dark:text-neutral-200 leading-7">
                  El nombre "Vitamina 3" nace de la metáfora de aportar energía y vitalidad a las marcas, diferenciándose de la competencia con originalidad.
                </p>
              </div>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Propuesta de valor</p>
                <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                  <li>Misión: Aportar una dosis de energía a las marcas de la manera más atípica posible.</li>
                  <li>Visión: Llevar a los clientes a la cúspide de la publicidad acompañándoles en cada paso.</li>
                </ul>
              </div>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Elementos visuales</p>
                <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                  <li>33,3% atípicamente diferente: cada miembro aporta un tercio único.</li>
                  <li>El 33,3% de tu dosis diaria de energía: metáfora nutricional aplicada al branding.</li>
                  <li>33,3% más cercano que nunca: enfoque personalizado.</li>
                </ul>
              </div>
              <div class="mt-3">
                <p class="text-sm font-semibold text-neutral-700 dark:text-neutral-200">Identidad</p>
                <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                  <li>Símbolo circular que representa sol y energía.</li>
                  <li>Color verde lima/amarillo verdoso.</li>
                  <li>Tipografía bold y moderna.</li>
                  <li>Sistema gráfico basado en porcentajes y fracciones.</li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section>
          <h2 id="capacidades-profesionales" class="mt-2 mb-4 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Capacidades profesionales
          </h2>
          <div class="grid gap-6 md:grid-cols-2">
            <div>
              <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Diseño gráfico</h3>
              <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                <li>Identidad corporativa y branding</li>
                <li>Diseño de logotipos</li>
                <li>Manuales de marca</li>
                <li>Diseño editorial</li>
              </ul>
            </div>
            <div>
              <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Contenido digital</h3>
              <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                <li>Diseño de plantillas para RRSS</li>
                <li>Creación de posts y contenido visual</li>
                <li>Redacción de copys publicitarios</li>
              </ul>
            </div>
            <div>
              <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Producción audiovisual</h3>
              <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                <li>Grabación de contenido</li>
                <li>Edición de video (Reels, TikToks)</li>
                <li>Postproducción</li>
              </ul>
            </div>
            <div>
              <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Desarrollo web</h3>
              <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                <li>Diseño de páginas web</li>
                <li>Tours virtuales</li>
                <li>WordPress y Elementor</li>
              </ul>
            </div>
          </div>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section>
          <h2 id="metodologia-de-trabajo" class="mt-2 mb-4 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Metodología de trabajo
          </h2>
          <div class="space-y-4">
            <div>
              <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Fase de investigación</h3>
              <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                <li>Análisis del cliente y sector</li>
                <li>Definición de misión y visión</li>
                <li>Identificación de valores de marca</li>
              </ul>
            </div>
            <div>
              <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Fase creativa</h3>
              <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                <li>Desarrollo conceptual</li>
                <li>Justificación estratégica del diseño</li>
                <li>Selección de paleta cromática con significado</li>
                <li>Creación de simbolismos</li>
              </ul>
            </div>
            <div>
              <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Fase de producción</h3>
              <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
                <li>Diseño de aplicaciones</li>
                <li>Desarrollo de entregables</li>
                <li>Presentación profesional</li>
              </ul>
            </div>
          </div>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section>
          <h2 id="filosofia-de-diseno" class="mt-2 mb-4 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Filosofía de diseño
          </h2>
          <p class="text-neutral-700 dark:text-neutral-200 leading-[1.8]">
            Enfoque estratégico donde cada elemento visual tiene un propósito y significado. Especialización en crear identidades que cuentan historias.
          </p>
          <ul class="list-disc pl-5 mt-3 text-neutral-700 dark:text-neutral-200 leading-7">
            <li>Simbolismo cultural: integración de elementos locales.</li>
            <li>Color con propósito: cada elección cromática responde a valores de marca.</li>
            <li>Simplicidad elegante: diseños limpios que comunican efectivamente.</li>
            <li>Narrativa visual: cada proyecto cuenta una historia coherente.</li>
          </ul>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section>
          <h2 id="sectores-de-experiencia" class="mt-2 mb-4 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Sectores de experiencia
          </h2>
          <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
            <li>Salud y farmacia</li>
            <li>Marketing y publicidad</li>
            <li>Gestión financiera e inversiones</li>
            <li>Cultura y narrativa</li>
            <li>Servicios creativos</li>
          </ul>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section>
          <h2 id="habilidades-complementarias" class="mt-2 mb-4 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Habilidades complementarias
          </h2>
          <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
            <li>Gestión de proyectos creativos</li>
            <li>Comunicación con clientes</li>
            <li>Trabajo en equipo (duplas creativas)</li>
            <li>Adaptabilidad multiplataforma</li>
            <li>Pensamiento estratégico</li>
          </ul>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section>
          <h2 id="idiomas" class="mt-2 mb-4 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Idiomas
          </h2>
          <ul class="list-disc pl-5 text-neutral-700 dark:text-neutral-200 leading-7">
            <li>Español (nativo)</li>
            <li>Gallego (nativo)</li>
            <li>Inglés (nivel profesional)</li>
          </ul>
        </section>

        <div class="w-full border-b-1 border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-8 mb-10"></div>

        <section>
          <h2 id="contacto" class="mt-2 mb-4 text-[28px] text-neutral-800 dark:text-neutral-200 font-brand">
            Contacto
          </h2>
          <p class="text-neutral-700 dark:text-neutral-200 leading-[1.8]">
            Para colaboraciones o proyectos, escribe a <a class="underline" href={`mailto:${siteConfig.mail}`}>{siteConfig.mail}</a>.
          </p>
        </section>
      </main>
    </div>
  </div>
</Layout>

<style>
.toc-sticky-wrapper {
  position: sticky;
  top: 8rem;
}
</style>
